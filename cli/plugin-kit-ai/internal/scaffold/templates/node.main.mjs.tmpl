import { ClaudeApp, CodexApp, allow, continue_ } from "./plugin-runtime.mjs";

{{- if eq .Platform "codex-runtime" }}
const app = new CodexApp().onNotify((event) => {
  void event;
  return continue_();
});
{{- else }}
const app = new ClaudeApp({
  allowedHooks: [
    "Stop",
    "PreToolUse",
    "UserPromptSubmit",
  {{- if .ClaudeExtendedHooks }}
    "SessionStart",
    "SessionEnd",
    "Notification",
    "PostToolUse",
    "PostToolUseFailure",
    "PermissionRequest",
    "SubagentStart",
    "SubagentStop",
    "PreCompact",
    "Setup",
    "TeammateIdle",
    "TaskCompleted",
    "ConfigChange",
    "WorktreeCreate",
    "WorktreeRemove",
  {{- end }}
  ],
  usage: {{- if .ClaudeExtendedHooks }} "main.mjs <hook-name>" {{- else }} "main.mjs <Stop|PreToolUse|UserPromptSubmit>" {{- end }},
})
  .onStop((event) => {
    void event;
    return allow();
  })
  .onPreToolUse((event) => {
    void event;
    return allow();
  })
  .onUserPromptSubmit((event) => {
    void event;
    return allow();
  })
{{- if .ClaudeExtendedHooks }}
  .on("SessionStart", (event) => {
    void event;
    return allow();
  })
  .on("SessionEnd", (event) => {
    void event;
    return allow();
  })
  .on("Notification", (event) => {
    void event;
    return allow();
  })
  .on("PostToolUse", (event) => {
    void event;
    return allow();
  })
  .on("PostToolUseFailure", (event) => {
    void event;
    return allow();
  })
  .on("PermissionRequest", (event) => {
    void event;
    return allow();
  })
  .on("SubagentStart", (event) => {
    void event;
    return allow();
  })
  .on("SubagentStop", (event) => {
    void event;
    return allow();
  })
  .on("PreCompact", (event) => {
    void event;
    return allow();
  })
  .on("Setup", (event) => {
    void event;
    return allow();
  })
  .on("TeammateIdle", (event) => {
    void event;
    return allow();
  })
  .on("TaskCompleted", (event) => {
    void event;
    return allow();
  })
  .on("ConfigChange", (event) => {
    void event;
    return allow();
  })
  .on("WorktreeCreate", (event) => {
    void event;
    return allow();
  })
  .on("WorktreeRemove", (event) => {
    void event;
    return allow();
  })
{{- end }};
{{- end }}

process.exit(app.run());
