package main

import (
	"os"

	hookplex "github.com/hookplex/hookplex/sdk"
	"github.com/hookplex/hookplex/sdk/codex"
)

func main() {
	app := hookplex.New(hookplex.Config{Name: "{{.ProjectName}}"})
	app.Codex().OnNotify(func(e *codex.NotifyEvent) *codex.Response {
		_ = e
		return codex.Continue()
	})
	os.Exit(app.Run())
}
